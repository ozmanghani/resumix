{
  "name": "resumix",
  "version": "1.1.1",
  "description": "Advanced PDF resume parser that extracts structured JSON data with schema-driven field selection and optional AI support",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && npm run build:types",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:types": "tsc --project tsconfig.types.json",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "clean": "rm -rf dist",
    "dev:server": "ts-node --project tsconfig.dev.json test-server.ts",
    "dev:cli": "ts-node --project tsconfig.dev.json test-cli.ts"
  },
  "keywords": [
    "resume",
    "parser",
    "pdf",
    "cv",
    "json",
    "extract",
    "nlp",
    "ai",
    "openai",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozmanghani/resumix.git"
  },
  "homepage": "https://github.com/ozmanghani/resumix#readme",
  "bugs": {
    "url": "https://github.com/ozmanghani/resumix/issues"
  },
  "author": "Osman Ahmadzai",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cors": "^2.8.6",
    "eslint": "^8.57.0",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "multer": "^2.0.2",
    "openai": "^6.33.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1"
  },
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
